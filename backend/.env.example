# Copy this file to .env and fill in your values

# MySQL connection string
DATABASE_URL=mysql+pymysql://root:YOUR_PASSWORD@127.0.0.1:3306/lms_db

# A long random string used to sign JWT tokens — change this!
SECRET_KEY=change-this-to-a-long-random-string

# How long a login token stays valid (minutes). 1440 = 24 hours
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Displayed in FastAPI docs (/docs)
APP_NAME=LMS API

# True = detailed error messages in API responses; False for production
DEBUG=True

# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:3000

# Default admin account created on first startup
ADMIN_EMAIL=admin@test.com
ADMIN_PASSWORD=admin123

# Where extracted SCORM ZIPs are stored on disk (relative to backend root)
SCORM_STORAGE_PATH=storage/scorm

# Max allowed SCORM ZIP upload size in bytes (150 MB = 157286400)
SCORM_MAX_ZIP_BYTES=157286400
